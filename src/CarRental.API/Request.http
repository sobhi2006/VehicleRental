@BaseUrl=http://localhost:5000
@ApiVersion=1
@PageNumber=1
@PageSize=10
@Id=1

### 1) Persons - Get All
GET {{BaseUrl}}/api/v{{ApiVersion}}/Persons?pageNumber={{PageNumber}}&pageSize={{PageSize}}

### 2) Persons - Get By Id
GET {{BaseUrl}}/api/v{{ApiVersion}}/Persons/{{Id}}

### 3) Persons - Create
POST {{BaseUrl}}/api/v{{ApiVersion}}/Persons
Content-Type: application/json

{
	"firstName": "John",
	"middleName": "A",
	"lastName": "Doe",
	"nationalNo": "NAT-1001",
	"dateOfBirth": "1995-01-15",
	"email": "john.doe@example.com",
	"phoneNumber": "+123456789",
	"address": "Main street 1"
}

### 4) Persons - Update
PUT {{BaseUrl}}/api/v{{ApiVersion}}/Persons
Content-Type: application/json

{
	"id": 1,
	"firstName": "John",
	"middleName": "A",
	"lastName": "Doe",
	"dateOfBirth": "1995-01-15",
	"email": "john.updated@example.com",
	"phoneNumber": "+123456789",
	"address": "Main street 2"
}

### 5) Persons - Delete
DELETE {{BaseUrl}}/api/v{{ApiVersion}}/Persons/{{Id}}

### 6) Persons - Update National No
PUT {{BaseUrl}}/api/v{{ApiVersion}}/Persons/UpdateNationalNo
Content-Type: application/json

{
	"id": 1,
	"nationalNo": "NAT-2001"
}

