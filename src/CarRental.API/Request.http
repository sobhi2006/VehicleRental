@BaseUrl=http://localhost:5000
@ApiVersion=1
@PageNumber=1
@PageSize=10
@Id=1

########################################
### PERSONS COLLECTION
########################################

### Persons - Get All
GET {{BaseUrl}}/api/v{{ApiVersion}}/Persons?pageNumber={{PageNumber}}&pageSize={{PageSize}}

### Persons - Get By Id
GET {{BaseUrl}}/api/v{{ApiVersion}}/Persons/{{Id}}

### Persons - Create
POST {{BaseUrl}}/api/v{{ApiVersion}}/Persons
Content-Type: application/json

{
	"firstName": "John",
	"middleName": null,
	"lastName": "Doe",
	"nationalNo": "NAT-1001",
	"dateOfBirth": "1995-01-15",
	"email": "john.doe@example.com",
	"phoneNumber": "+123456789",
	"address": "Main street 1"
}

### Persons - Update
PUT {{BaseUrl}}/api/v{{ApiVersion}}/Persons
Content-Type: application/json

{
	"id": 1,
	"firstName": "John",
	"middleName": "A",
	"lastName": "Doe",
	"dateOfBirth": "1995-01-15",
	"email": "john.updated@example.com",
	"phoneNumber": "+123456789",
	"address": "Main street 2"
}

### Persons - Delete
DELETE {{BaseUrl}}/api/v{{ApiVersion}}/Persons/{{Id}}

### Persons - Update National No
PUT {{BaseUrl}}/api/v{{ApiVersion}}/Persons/UpdateNationalNo
Content-Type: application/json

{
	"id": 2,
	"nationalNo": "NAT-2001"
}

########################################
### DRIVERS COLLECTION
########################################

### Drivers - Get All
GET {{BaseUrl}}/api/v{{ApiVersion}}/Drivers?pageNumber={{PageNumber}}&pageSize={{PageSize}}

### Drivers - Get By Id
GET {{BaseUrl}}/api/v{{ApiVersion}}/Drivers/{{Id}}

### Drivers - Create
POST {{BaseUrl}}/api/v{{ApiVersion}}/Drivers
Content-Type: application/json

{
	"personId": 2,
	"driverLicenseNumber": "DL-1001",
	"driverLicenseExpiryDate": "2030-12-31"
}

### Drivers - Update
PUT {{BaseUrl}}/api/v{{ApiVersion}}/Drivers/{{Id}}
Content-Type: application/json

{
	"id": 9,
	"personId": 2,
	"driverLicenseNumber": "DL-1001-UPDATED",
	"driverLicenseExpiryDate": "2031-12-31"
}

### Drivers - Delete
DELETE {{BaseUrl}}/api/v{{ApiVersion}}/Drivers/{{Id}}

